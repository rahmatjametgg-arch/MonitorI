# ======================================================
# SPIDERMAT OTP BOT — Konfigurasi Environment
# Salin file ini menjadi .env lalu isi semua nilainya
# ======================================================

# Token bot dari @BotFather
BOT_TOKEN=1234567890:AAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# User ID Telegram kamu (owner bot) — cek lewat @userinfobot
OWNER_ID=123456789

# ID channel log (angka negatif, misal -1001234567890)
# Kosongkan jika tidak mau pakai log channel
LOG_CHANNEL_ID=-1001234567890

# Username channel/grup yang wajib di-join sebelum pakai bot
# Format: username1,username2 (tanpa @ dan tanpa spasi ekstra)
FORCE_JOIN_CHANNELS=namakanelmu,namagrupmu

# Link kontak owner & channel (untuk tampil di pesan /start)
LINK_OWNER=t.me/usernamemu
LINK_CHANNEL=https://t.me/namakanelmu

# ── Pakasir QRIS Payment (opsional — kosongkan jika tidak pakai) ──
PAKASIR_PROJECT=
PAKASIR_API_KEY=
