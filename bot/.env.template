# ============================================================
# SPIDERMAT OTP BOT — Environment Variables Template
# Copy isi file ini ke Railway / hosting lainnya
# ============================================================

# ── WAJIB DIISI ──────────────────────────────────────────────
# Token bot dari @BotFather
BOT_TOKEN=

# User ID Telegram kamu (cek via @userinfobot)
OWNER_ID=

# ID channel untuk log aktivitas (awali dengan -)
# Kosongkan jika tidak mau pakai log channel
LOG_CHANNEL_ID=

# Username/link akun owner untuk tombol kontak
# Contoh: t.me/usernameKamu
LINK_OWNER=t.me/usernameKamu

# Link channel utama bot (untuk info/update)
# Contoh: t.me/channelKamu  
LINK_CHANNEL=t.me/channelKamu

# ── OPSIONAL ─────────────────────────────────────────────────
# Channel/grup yang WAJIB di-join user sebelum pakai bot
# Isi username tanpa @, pisah koma jika lebih dari satu
# Contoh: SpidermatChannel,SpidermatGroup
# Kosongkan jika tidak mau force join
FORCE_JOIN_CHANNELS=

# ── DATABASE (diisi otomatis oleh Railway Plugin) ─────────────
# Jangan diubah manual — Railway isi ini sendiri saat kamu
# tambahkan PostgreSQL plugin di dashboard Railway
DATABASE_URL=

# ── PAKASIR (untuk auto-payment, OPSIONAL) ────────────────────
# Biarkan kosong jika pakai QRIS manual
PAKASIR_PROJECT=
PAKASIR_API_KEY=
